{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Customer Support Ticket",
  "type": "object",
  "required": [
    "ticket_id",
    "customer_id",
    "subject",
    "description",
    "priority",
    "status",
    "channel",
    "created_at"
  ],
  "properties": {
    "ticket_id": {
      "type": "string",
      "minLength": 5
    },
    "customer_id": {
      "type": "string",
      "minLength": 5
    },
    "subject": {
      "type": "string",
      "minLength": 5
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "pending",
        "resolved",
        "closed"
      ]
    },
    "channel": {
      "type": "string",
      "enum": [
        "email",
        "chat",
        "phone",
        "web"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "ar"
      ]
    },
    "agent_response": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}